# Network Configuration
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
PRIVATE_KEY=your_private_key_here

# Contract Addresses (populated after deployment)
MARKET_REGISTRY_ADDRESS=
TRADING_ENGINE_ADDRESS=
SETTLEMENT_MANAGER_ADDRESS=

# CRE Workflow Configuration
WORKFLOW_PRIVATE_KEY=your_workflow_private_key_here
WORKFLOW_STATE_PATH=./workflow_state

# Data Source API Keys
NEWS_API_KEY=your_news_api_key
MARITIME_API_KEY=your_maritime_api_key
LOGISTICS_API_KEY=your_logistics_api_key

# Monitoring Configuration
POLL_INTERVAL_SECONDS=300
CONSENSUS_THRESHOLD=0.67
MAX_RETRIES=5
